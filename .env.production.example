# --------- PRODUCCIÓN (Azure App Service) ---------
# Copia este archivo como .env en Azure App Service > Configuration > Application Settings
# O configúralos directamente en el portal de Azure

# REQUERIDO: Cambia este secreto por algo aleatorio y seguro
NEXTAUTH_SECRET=CAMBIA-ESTO-POR-UN-SECRETO-ALEATORIO-LARGO-Y-SEGURO

# REQUERIDO: Tu URL de Azure (se actualiza después del deploy)
NEXTAUTH_URL=https://tu-app.azurewebsites.net

# Base de datos SQLite (usa almacenamiento persistente de Azure)
DATABASE_URL="file:/home/site/data/nexus.db"

# Secreto para el endpoint del cron de bots
CRON_SECRET=cambia-este-secreto-tambien

# Puerto (Azure lo asigna automáticamente)
PORT=8080

# Node environment
NODE_ENV=production

# Node.js version for Azure
WEBSITE_NODE_DEFAULT_VERSION=~24
